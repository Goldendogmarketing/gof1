# --- Payment provider switch ---------------------------------------------
# Which provider /api/checkout should use. One of: "square" | "clover".
# Defaults to "square" if unset (back-compat).
PAYMENT_PROVIDER="square"

# --- Clover Hosted Checkout ---------------------------------------------
# CLOVER_ENVIRONMENT: "sandbox" | "production"
# CLOVER_API_TOKEN:    Generated in Clover Dashboard → Setup → API Tokens
#                      (choose "Hosted checkout" integration type).
# CLOVER_MERCHANT_ID:  13-char mId, visible in the dashboard URL or
#                      Account & Setup → Business Information.
# CLOVER_WEBHOOK_SIGNATURE_KEY: Generated once you register the webhook URL at
#                      Settings → Ecommerce → Hosted Checkout → Webhook URL → Generate.
CLOVER_ENVIRONMENT="sandbox"
CLOVER_API_TOKEN=""
CLOVER_MERCHANT_ID=""
CLOVER_WEBHOOK_SIGNATURE_KEY=""

RESEND_API_KEY=""
# Verified-domain sender address shown to the customer.
ORDER_FROM_EMAIL="Greek Olive Fusion <orders@greekolivefusion.com>"
# Inbox that gets a brief "you got a paid order" alert per sale.
OWNER_NOTIFICATION_EMAIL="joe@greekolivefusion.com"
# Inbox that gets the full fulfillment packet (line items + shipping address + plain-text copy).
DROPSHIP_NOTIFICATION_EMAIL="fulfillment@your-dropship-partner.com"

BLOB_READ_WRITE_TOKEN=""
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
